% (i, i), (i, o) - deterministic
replace_np([], []):-!. % L is empty
replace_np([H|T], [HR|TR]):-
    is_prime(H), !, % do not check if it's not prime, cut it here, do not check the other clause
    HR is H,
    replace_np(T, TR).
replace_np([H|T], [HR|TR]):-
    % is NOT prime, we know from the cut
    get_proper_divisors(H, D),
    list_sum(D, S), % S is the sum of its divisors, replace with it
    HR is S,
    replace_np(T, TR).

