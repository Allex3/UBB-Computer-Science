get_proper_divisors_aux(X, X, []):-!. % X = N, finished all divisors
get_proper_divisors_aux(X, N, [H|T]):-
    M is X mod N,
    M == 0, !,
    N1 is N+1,
    H is N, % add the divisor
    get_proper_divisors_aux(X, N1, T). % add the divisor
get_proper_divisors_aux(X, N ,D):-
    N1 is N+1,
    get_proper_divisors_aux(X, N1, D). % ignore it


get_proper_divisors(X, D):-
    get_proper_divisors_aux(X, 2, D).


is_prime(X):-
    get_proper_divisors(X, D),
    D == [].


is_list_prime([]):-!.
is_list_prime([H|T]):-
    is_prime(H),
